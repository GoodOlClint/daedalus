{
  "listen_addr": ":8080",
  "database_url": "postgres://zakros:REPLACE_POSTGRES_PASSWORD@172.16.140.100:5432/zakros?sslmode=disable",

  "signing_key_ref": "minos/signing-key",
  "admin_token_ref": "minos/admin-token",
  "github_webhook_secret_ref": "cerberus/github-webhook",

  "minos_pod_url": "http://172.16.140.101:8080",
  "github_broker_pod_url": "http://172.16.140.101:8082",

  "admin": {
    "surface": "discord",
    "surface_id": "REPLACE_YOUR_DISCORD_USER_ID"
  },

  "project": {
    "id": "zakros-phase1",
    "backend": "k3s",
    "plugin_image": "zakros/claude-code:local",
    "argus_sidecar_image": "zakros/argus-sidecar:local",
    "agent_mention_handle": "",
    "default_workspace_size": "small",
    "default_base_branch": "main",
    "default_repo_url": "REPLACE_DEFAULT_REPO_URL",
    "default_budget": {
      "wall_clock_seconds": 1800,
      "max_tool_calls": 200
    },
    "communication": {
      "thread_surface": "discord"
    },
    "thread_parent": "REPLACE_DISCORD_CHANNEL_ID",
    "capabilities": {
      "injected_credentials": [
        {
          "env_var": "CLAUDE_CODE_OAUTH_TOKEN",
          "credentials_ref": "claude-code/oauth-token"
        }
      ],
      "mcp_endpoints": [
        {
          "name": "github",
          "url": "http://172.16.140.101:8082",
          "scopes": ["clone"]
        }
      ]
    }
  },

  "discord": {
    "bot_token_ref": "hermes/discord-bot-token"
  },

  "hibernation": {
    "reminder_after": "24h",
    "abandon_after": "72h",
    "sweep_interval": "5m"
  }
}
