{
  "credentials": {
    "minos/signing-key": {
      "_comment": "PEM-encoded Ed25519 private key. Generate with `minosctl gen-signing-key`.",
      "value": "REPLACE_WITH_minosctl_gen_signing_key_PRIVATE_BLOCK"
    },
    "minos/signing-key-pub": {
      "_comment": "PEM-encoded Ed25519 public key — github-broker (and future brokers) verify pod JWTs with it.",
      "value": "REPLACE_WITH_minosctl_gen_signing_key_PUBLIC_BLOCK"
    },
    "minos/admin-token": {
      "value": "REPLACE_WITH_openssl_rand_base64_32"
    },
    "minos/iris-token": {
      "_comment": "Iris's long-lived JWT. Mint with `minosctl mint-iris-token` after Minos is up.",
      "value": "REPLACE_WITH_minosctl_mint_iris_token_OUTPUT"
    },
    "cerberus/github-webhook": {
      "value": "REPLACE_WITH_github_app_webhook_secret"
    },
    "github/app-private-key": {
      "_comment": "PEM-encoded GitHub App private key. github-broker mints installation tokens with it.",
      "value": "REPLACE_WITH_github_app_private_key_PEM"
    },
    "hermes/discord-bot-token": {
      "value": "REPLACE_WITH_discord_bot_token"
    },
    "claude-code/oauth-token": {
      "value": "REPLACE_WITH_output_of_claude_setup_token"
    },
    "anthropic/api-key": {
      "_comment": "Required for Iris. Get from https://console.anthropic.com — the claude-code/oauth-token above does NOT work for the bare Messages API.",
      "value": "REPLACE_WITH_anthropic_api_key"
    },
    "cloudflared/tunnel-token": {
      "value": "REPLACE_WITH_cloudflare_tunnel_token"
    }
  }
}
